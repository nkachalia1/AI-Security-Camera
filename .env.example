# Camera
# Leave blank for a camera plugged into the Pi, or set to an MJPEG/RTSP/HTTP source.
# Example for laptop webcam streaming to the Pi:
# VISION_CAMERA_SOURCE=http://10.0.0.50:8090/stream.mjpg
VISION_CAMERA_SOURCE=
VISION_CAMERA_INDEX=0
VISION_FRAME_WIDTH=1280
VISION_FRAME_HEIGHT=720
VISION_FPS=15

# Storage
VISION_DATA_DIR=./data
VISION_CLIP_SECONDS_BEFORE=4
VISION_CLIP_SECONDS_AFTER=8
VISION_RETENTION_DAYS=14

# Detection
VISION_DETECTION_INTERVAL=5
VISION_CONFIDENCE_THRESHOLD=0.45
VISION_NMS_THRESHOLD=0.45
VISION_MIN_MOTION_AREA=5000
VISION_MOTION_MERGE_PIXELS=36
VISION_MAX_MOTION_DETECTIONS=3
VISION_EMIT_GENERIC_MOTION_EVENTS=false
VISION_ONNX_MODEL=
VISION_ONNX_INPUT_SIZE=640
VISION_LABELS_FILE=./models/coco.names
VISION_DETECT_LABELS=person,backpack,handbag,suitcase,laptop,cell phone,bottle,cup,book,keyboard,mouse,remote,chair,tv

# Simple named zones as x1;y1;x2;y2 in normalized coordinates.
# Example: workbench occupies the lower-right quadrant of the frame.
VISION_ZONES=workbench:0.58;0.45;0.98;0.98,entry:0.00;0.15;0.22;0.95

# Optional LLM summarization.
# Set VISION_LLM_PROVIDER=ollama and run a local model, or set openai with an API key.
VISION_LLM_PROVIDER=rules
VISION_OLLAMA_URL=http://127.0.0.1:11434/api/generate
VISION_OLLAMA_MODEL=llama3.1
OPENAI_API_KEY=
VISION_OPENAI_MODEL=gpt-4.1-mini

# Web service
VISION_HOST=0.0.0.0
VISION_PORT=8080
VISION_LOG_LEVEL=info
